#!/bin/sh
# Pre-commit dispatcher — runs all executable scripts in pre-commit.d/
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)/pre-commit.d"
[ -d "$HOOK_DIR" ] || exit 0

status=0
for hook in "$HOOK_DIR"/*; do
    [ -x "$hook" ] || continue
    name="$(basename "$hook" | sed 's/^[0-9]*-//;s/\.sh$//')"
    skip=$(git config --bool "hooks.skip-${name}" 2>/dev/null || true)
    if [ "$skip" = "true" ]; then
        continue
    fi
    "$hook"
    rc=$?
    if [ $rc -ne 0 ]; then
        status=$rc
    fi
done
exit $status
