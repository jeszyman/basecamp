# -*- mode: snippet -*-
# name: comment-wrap
# key: cw
# --
`(let ((text yas-selected-text))
   (if text
       (with-temp-buffer
         (insert text)
         (let ((fill-column 78))  ; 80 - 2 for "# "
           (fill-region (point-min) (point-max)))
         (goto-char (point-min))
         (while (not (eobp))
           (beginning-of-line)
           (insert "# ")
           (forward-line 1))
         (buffer-string))
     "# "))`$0