# -*- mode: snippet -*-
# key: parse_args
# expand-env: ((yas-indent-line 'fixed))
# --
parse_args() {
  # It parses once, then populates named variables for downstream functions to consume.

  # 1) Help is a successful control path:
  if [[ "\${1:-}" == "-h" || "\${1:-}" == "--help" ]]; then
    print_usage
    exit 0
  fi

  # 2) CLI misuse (invoked incorrectly):
  if [[ \$# -lt "\$${1:MIN_REQUIRED_ARGS}" ]]; then
    echo "Error: Missing required arguments." >&2
    print_usage >&2
    exit 2
  fi

  # 3) Input argument declarations:
  declare -g ${2:required_arg 1}="\$1"

  # 4) Runtime/domain validation (invocation OK but inputs invalid, >&2; exit 1):

  # 5) Compute derived variables as needed. .
}
